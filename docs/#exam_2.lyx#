\begin_layout Section*
Problem 1.2
\end_layout

\begin_layout Standard
Consider the time-invariant, discrete-time, nonlinear state space system.
\begin_inset Formula 
\begin{align*}
\dot{s} & =f\left(s_{k},u_{k}\right),\\
f\left(s,u\right) & \triangleq\left[\begin{array}{c}
s_{1}+u_{2}\cos\left(s_{3}+u_{1}\right)\\
s_{2}+u_{2}\sin\left(s_{3}+u_{1}\right)\\
s_{3}+u_{1}+u_{3}
\end{array}\right]
\end{align*}

\end_inset

where 
\begin_inset Formula $u\triangleq\left[\begin{array}{ccc}
u_{1}^{\top} & u_{2}^{\top} & u_{3}^{\top}\end{array}\right]^{\top}=\left[\begin{array}{ccc}
\delta_{\text{rot}1}^{\top} & \delta_{\text{trans}}^{\top} & \delta_{\text{rot}2}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{3}$
\end_inset

 and 
\begin_inset Formula $s\triangleq\left[\begin{array}{ccc}
x^{\top} & y^{\top} & \theta^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{3}$
\end_inset

.
 Let the corresponding measurement model be
\begin_inset Formula 
\[
h\left(s\right)\triangleq\arctan\left(\frac{\ell_{y}-s_{2}}{\ell_{x}-s_{1}}\right)-s_{3}
\]

\end_inset

Take the Jacobians.
\begin_inset Formula 
\begin{align*}
\frac{df}{du} & =\left[\begin{array}{ccc}
\frac{df_{1}}{du_{1}} & \frac{df_{1}}{du_{2}} & \frac{df_{1}}{du_{3}}\\
\frac{df_{2}}{du_{1}} & \frac{df_{2}}{du_{2}} & \frac{df_{2}}{du_{3}}\\
\frac{df_{3}}{du_{1}} & \frac{df_{3}}{du_{2}} & \frac{df_{3}}{du_{3}}
\end{array}\right]\\
 & =\left[\begin{array}{ccc}
-u_{2}\sin\left(s_{3}+u_{1}\right) & \cos\left(s_{3}+u_{1}\right) & 0\\
u_{2}\cos\left(s_{3}+u_{1}\right) & \sin\left(s_{3}+u_{1}\right) & 0\\
1 & 0 & 1
\end{array}\right]
\end{align*}

\end_inset

and 
\begin_inset Formula 
\begin{align*}
\frac{df}{ds} & =\left[\begin{array}{ccc}
\frac{df_{1}}{ds_{1}} & \frac{df_{1}}{ds_{2}} & \frac{df_{1}}{ds_{3}}\\
\frac{df_{2}}{ds_{1}} & \frac{df_{2}}{ds_{2}} & \frac{df_{2}}{ds_{3}}\\
\frac{df_{3}}{ds_{1}} & \frac{df_{3}}{ds_{2}} & \frac{df_{3}}{ds_{3}}
\end{array}\right]\\
 & =\left[\begin{array}{ccc}
1 & 0 & -u_{2}\sin\left(s_{3}+u_{1}\right)\\
0 & 1 & u_{2}\cos\left(s_{3}+u_{1}\right)\\
0 & 0 & 1
\end{array}\right]
\end{align*}

\end_inset

and
\begin_inset Formula 
\begin{align*}
\frac{dh}{ds} & =\left[\begin{array}{c}
\frac{dh_{1}}{ds_{1}}\\
\frac{dh_{1}}{ds_{2}}\\
\frac{dh_{1}}{ds_{3}}
\end{array}\right]\\
 & =\left[\begin{array}{c}
\frac{1}{1+\left(\frac{\ell_{y}-s_{2}}{\ell_{x}-s_{1}}\right)^{2}}\cdot\left(\ell_{y}-s_{2}\right)\left(\ell_{x}-s_{1}\right)^{-2}\\
\frac{1}{1+\left(\frac{\ell_{y}-s_{2}}{\ell_{x}-s_{1}}\right)^{2}}\cdot-\left(\ell_{x}-s_{1}\right)^{-1}\\
-1
\end{array}\right]\\
 & =\left[\begin{array}{c}
\frac{\ell_{y}-s_{2}}{\left(\ell_{x}-s_{1}\right)^{2}+\left(\ell_{y}-s_{2}\right)^{2}}\\
\frac{s_{1}-\ell_{x}}{\left(\ell_{x}-s_{1}\right)^{2}+\left(\ell_{y}-s_{2}\right)^{2}}\\
-1
\end{array}\right]
\end{align*}

\end_inset

Thus, at a given operating point 
\begin_inset Formula $\left(s,u\right)\in\mathbb{R}^{3}\times\mathbb{R}^{3}$
\end_inset

, we have the linear system
\begin_inset Formula 
\begin{align*}
s_{k} & =\left(\frac{df}{ds}\right)_{k}\Delta s_{k}+\left(\frac{df}{du}\right)_{k}\Delta u_{k}+\varepsilon\\
y_{k} & =\left(\frac{dh}{ds}\right)_{k}s_{k}+\delta
\end{align*}

\end_inset

where 
\begin_inset Formula $\varepsilon$
\end_inset

 and 
\begin_inset Formula $\delta$
\end_inset

 are zero-mean Gaussian disturbances and noise, respectively, each with
 known covariances.
