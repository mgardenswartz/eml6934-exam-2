\begin_layout Standard
Bayes rules
\begin_inset Formula 
\[
p\left(x,y\right)=p\left(x|y\right)p\left(y\right)=p\left(y|x\right)p\left(x\right)
\]

\end_inset

Law of total probability
\begin_inset Formula 
\begin{align*}
p\left(x\right) & =\intop p\left(x,y\right)dy\\
p\left(x\right) & =\sum_{y}p\left(x,y\right)
\end{align*}

\end_inset

Law of total probability with conditioning
\begin_inset Formula 
\[
p\left(x|z\right)=\sum_{y}p\left(y|z\right)p\left(x|y,z\right)
\]

\end_inset

Corollary of Bayes + law of total probability:
\begin_inset Formula 
\begin{align*}
p\left(x\right) & =\intop p\left(x|y\right)p\left(y\right)dy\\
p\left(x\right) & =\sum_{y}p\left(x|y\right)p\left(y\right)
\end{align*}

\end_inset

Independence
\begin_inset Formula 
\[
p\left(x,y\right)=p\left(x\right)p\left(y\right)\iff p\left(x|y\right)=p\left(x\right)
\]

\end_inset

Normalization
\begin_inset Formula 
\begin{align*}
p\left(x|y\right) & =\underbrace{\frac{1}{\sum_{y}p\left(x,y\right)}p\left(y|x\right)}_{\eta}p\left(x\right)\\
 & =\underbrace{\frac{1}{\sum_{y}p\left(y|x\right)p\left(x\right)}p\left(y|x\right)}_{\eta}p\left(x\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Section*
Problem 1.1
\end_layout

\begin_layout Standard
We are given that
\begin_inset Formula 
\begin{align*}
P\text{\left(x_{t+1}=clean|x_{t}=dirty,u_{t}=clean\right)} & =0.6\\
P\text{\left(x_{t+1}=dirty|x_{t}=clean,u_{t}=clean\right)} & =0\\
P\left(z_{t}=clean|x_{t}=dirty\right) & =0.2\\
P\left(z_{t}=clean|x_{t}=clean\right) & =0.6\\
z_{t+1} & =clean
\end{align*}

\end_inset

The robot:
\end_layout

\begin_layout Enumerate
Lands on a new tile
\end_layout

\begin_layout Enumerate
Cleans it (without sensing) at 
\begin_inset Formula $t$
\end_inset


\end_layout

\begin_layout Enumerate
Then senses if it is clean or not at 
\begin_inset Formula $t+1$
\end_inset


\end_layout

\begin_layout Standard
We assume no prior knowledge of the floor tile we're over:
\begin_inset Formula 
\[
P\left(x_{t}=clean\right)=c\in\left[0,1\right]
\]

\end_inset

We want a plot of:
\begin_inset Formula 
\[
P\left(x_{t+1}=clean|z_{t+1}=clean\right).
\]

\end_inset

Use the Bayes filter (Table 2.1 from Sebastian Thrun's book).
 Step 0: initialize the belief
\begin_inset Formula 
\[
bel\left(x_{t}=clean\right)=c
\]

\end_inset

Step 1: compute the time update (prediction a.k.a posterior belief before
 the measurement).
 
\begin_inset Formula 
\begin{align*}
\overline{bel}\left(x_{t+1}=clean\right) & =\intop p\left(x_{t+1}=clean|u_{t+1}=clean,x_{t}=unknown\right)bel\left(x_{t}\right)dx_{t}\\
\\
 & =p\left(x_{t+1}=clean|u_{t+1}=clean,x_{t}=clean\right)p\left(x_{t}=clean\right)\\
 & +p\left(x_{t+1}=clean|u_{t+1}=clean,x_{t}=dirty\right)p\left(x_{t}=dirty\right)\\
\\
 & =p\left(x_{t+1}=clean|u_{t+1}=clean,x_{t}=clean\right)p\left(x_{t}=clean\right)\\
 & +p\left(x_{t+1}=clean|u_{t+1}=clean,x_{t}=dirty\right)p\left(x_{t}=dirty\right)\\
\\
 & =1\cdot c+0.6\cdot(1-c)\\
 & =0.4c+0.6
\end{align*}

\end_inset

Step 2: compute the measurement update (posterior belief after the measurement).
 Use the law of total probability and Bayes rule.
\begin_inset Formula 
\begin{align*}
bel\left(x_{t+1}=clean\right) & =\underbrace{\frac{1}{p\left(z_{t+1}=clean\right)}}_{\eta}p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)\\
 & =\frac{1}{\sum_{x}p\left(z_{t+1}=clean,x_{t+1}\right)}p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)\\
 & =\frac{1}{\sum_{x}p\left(z_{t+1}=clean|x_{t+1}\right)p\left(x_{t+1}\right)}p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)\\
 & =\frac{p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)}{p\left(z_{t+1}=clean|x_{t+1}=clean\right)p\left(x_{t+1}=clean\right)+p\left(z_{t+1}=clean|x_{t+1}=dirty\right)p\left(x_{t+1}=dirty\right)}\\
 & =\frac{p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)}{p\left(z_{t+1}=clean|x_{t+1}=clean\right)p\left(x_{t+1}=clean\right)+p\left(z_{t+1}=clean|x_{t+1}=dirty\right)\left(1-p\left(x_{t+1}=clean\right)\right)}\\
 & =\frac{p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)}{p\left(z_{t+1}=clean|x_{t+1}=clean\right)\overline{bel}\left(x_{t+1}=clean\right)+p\left(z_{t+1}=clean|x_{t+1}=dirty\right)\left(1-\overline{bel}\left(x_{t+1}=clean\right)\right)}\\
 & =\frac{0.6\cdot\left(0.4c+0.6\right)}{0.6\cdot\left(0.4c+0.6\right)+0.2\left(1-\left(0.4c+0.6\right)\right)}\\
 & =\frac{0.24c+0.36}{0.24c+0.36+0.2-0.2\left(0.4c+0.6\right)}\\
 & =\frac{0.24c+0.36}{0.24c+0.36+0.2-0.08c-0.12}\\
 & =\frac{0.24c+0.36}{0.16c+0.44}
\end{align*}

\end_inset

